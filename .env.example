# ─── Google Gemini (chat + embeddings, free tier) ─────────────────────
# https://aistudio.google.com/apikey  ->  Create API key  (sin tarjeta)
GOOGLE_GENERATIVE_AI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Base vectorial (Upstash Vector) ──────────────────────────────────
# https://console.upstash.com  ->  Vector  ->  Create Index
# IMPORTANTE: crea el índice con 768 dimensiones y métrica COSINE
UPSTASH_VECTOR_REST_URL=https://xxxxx.upstash.io
UPSTASH_VECTOR_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Fuentes de datos ─────────────────────────────────────────────────

# Contexto "Mercurio" — web Odoo principal
# El crawler parte del sitemap en /sitemap.xml
ODOO_SITE_URL=https://mercurio.lahavane.com

# Contexto "metodología del receptivo y experiencias" — web Ghost
# Por defecto apunta a destino-world.fr; cámbialo si es necesario
DESTINO_SITE_URL=https://destino-world.fr
