      "updated": 1781414493486,
      "link": null,
      "locked": false,
      "text": "📤 EXPORTAR  →  npm run export\n\nLlama Upstash list-vectors API → guarda en data/backup-YYYY-MM-DD.json\nIncluye: id · vector 768d · metadata (text, url, title, source)\nAlmacenar en GitHub (LFS) o Google Drive / S3",
      "fontSize": 11,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 70,
      "containerId": null,
      "originalText": "📤 EXPORTAR  →  npm run export\n\nLlama Upstash list-vectors API → guarda en data/backup-YYYY-MM-DD.json\nIncluye: id · vector 768d · metadata (text, url, title, source)\nAlmacenar en GitHub (LFS) o Google Drive / S3",
      "lineHeight": 1.25,
      "index": "bG",
      "autoResize": true
    },
